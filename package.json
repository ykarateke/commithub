{
  "name": "commithub",
  "displayName": "CommitHub",
  "description": "AI-powered Git commit message generator.",
  "version": "1.1.1",
  "publisher": "YasinKarateke",
  "repository": {
    "type": "git",
    "url": "https://github.com/ykarateke/commithub.git"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": ["onStartupFinished"],
  "icon": "images/commithub-sparkle.png",
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "CommitHub",
      "properties": {
        "commithub.provider": {
          "type": "string",
          "default": "openai",
          "enum": ["openai", "anthropic", "google_gemini", "zhipu_glm", "xai_grok", "deepseek", "mistral", "ollama", "openrouter", "groq", "together"],
          "description": "AI provider for commit message generation"
        },
        "commithub.model": {
          "type": "string",
          "default": "gpt-4o",
          "description": "AI model name (see provider documentation)"
        },
        "commithub.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Custom API base URL (leave empty for provider default)"
        },
        "commithub.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "AI temperature (0=deterministic, 2=creative)"
        },
        "commithub.maxTokens": {
          "type": "number",
          "default": 2000,
          "minimum": 50,
          "description": "Maximum tokens for AI response"
        },
        "commithub.language": {
          "type": "string",
          "default": "auto",
          "enum": ["auto", "en", "tr", "de", "fr", "es", "pt", "it", "nl", "pl", "ru", "ja", "ko", "zh-CN", "zh-TW", "ar", "hi", "sv", "da", "fi", "nb", "cs", "hu", "ro", "uk", "el", "th", "vi", "bg", "hr", "sk", "sl"],
          "description": "Commit message language"
        },
        "commithub.maxLength": {
          "type": "number",
          "default": 72,
          "minimum": 20,
          "description": "Maximum commit subject line length"
        },
        "commithub.conventionalCommit": {
          "type": "boolean",
          "default": true,
          "description": "Use Conventional Commits format (feat:, fix:, etc.)"
        },
        "commithub.includeBody": {
          "type": "boolean",
          "default": true,
          "description": "Include detailed body in commit message"
        },
        "commithub.includeFooter": {
          "type": "boolean",
          "default": false,
          "description": "Include footer (breaking changes, issue refs)"
        },
        "commithub.emoji": {
          "type": "boolean",
          "default": false,
          "description": "Add emoji prefix to commit messages"
        },
        "commithub.tone": {
          "type": "string",
          "default": "auto",
          "enum": ["auto", "formal", "casual", "technical"],
          "description": "Commit message tone"
        },
        "commithub.scopeDetection": {
          "type": "boolean",
          "default": true,
          "description": "Auto-detect commit scope from file paths"
        },
        "commithub.breakingChanges": {
          "type": "boolean",
          "default": true,
          "description": "Auto-detect breaking API changes"
        },
        "commithub.maxDiffSize": {
          "type": "number",
          "default": 8000,
          "minimum": 1000,
          "description": "Truncate diff to this many characters before sending to AI"
        },
        "commithub.excludeFiles": {
          "type": "string",
          "default": "",
          "description": "Comma-separated glob patterns to exclude from diff analysis"
        },
        "commithub.untrackedFileMaxLines": {
          "type": "number",
          "default": 100,
          "minimum": 10,
          "description": "Max lines per untracked file sent to AI (truncates the rest)"
        },
        "commithub.summaryModeThreshold": {
          "type": "number",
          "default": 15000,
          "minimum": 1000,
          "description": "Switch to summary-only mode if total diff chars exceed this"
        },
        "commithub.conventionalTypes": {
          "type": "string",
          "default": "feat, fix, chore, docs, style, refactor, perf, test, ci, build, revert",
          "description": "Comma-separated conventional commit types allowed"
        }
      }
    },
    "commands": [
      {
        "command": "commithub.generateCommit",
        "title": "Generate Commit Message",
        "icon": "images/commithub-sparkle.svg"
      },
      { "command": "commithub.setApiKey", "title": "Set API Key" },
      { "command": "commithub.setProvider", "title": "Set AI Provider" },
      { "command": "commithub.setModel", "title": "Set Model" },
      { "command": "commithub.setBaseUrl", "title": "Set Base URL" },
      { "command": "commithub.setTemperature", "title": "Set Temperature" },
      { "command": "commithub.setMaxTokens", "title": "Set Max Tokens" },
      { "command": "commithub.setLanguage", "title": "Set Language" },
      { "command": "commithub.setMaxLength", "title": "Set Max Length" },
      { "command": "commithub.setConventionalCommit", "title": "Toggle Conventional Commits" },
      { "command": "commithub.setIncludeBody", "title": "Toggle Include Body" },
      { "command": "commithub.setIncludeFooter", "title": "Toggle Include Footer" },
      { "command": "commithub.setEmoji", "title": "Toggle Emoji" },
      { "command": "commithub.setTone", "title": "Set Message Tone" },
      { "command": "commithub.setScopeDetection", "title": "Toggle Scope Detection" },
      { "command": "commithub.setBreakingChanges", "title": "Toggle Breaking Changes Detection" },
      { "command": "commithub.setMaxDiffSize", "title": "Set Max Diff Size" },
      { "command": "commithub.setExcludeFiles", "title": "Set Exclude Files" },
      { "command": "commithub.setConventionalTypes", "title": "Set Conventional Types" },
      { "command": "commithub.showStats", "title": "Show Statistics" },
      { "command": "commithub.testConnection", "title": "Test Connection" },
      { "command": "commithub.fetchModels", "title": "Fetch Models from API" }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "commithub.generateCommit",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "view/title": []
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "commithub",
          "title": "CommitHub",
          "icon": "images/commithub-sparkle.svg"
        }
      ]
    },
    "views": {
      "commithub": [
        {
          "type": "tree",
          "id": "commithub.settingsView",
          "name": "Settings"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}

{
  "name": "commithub",
  "displayName": "CommitHub",
  "description": "AI-powered Git commit message generator.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "CommitHub",
      "properties": {
        "commithub.provider": {
          "type": "string",
          "default": "openai",
          "enum": ["openai", "anthropic", "ollama"],
          "description": "AI provider for commit message generation"
        },
        "commithub.model": {
          "type": "string",
          "default": "gpt-4o",
          "description": "AI model name"
        },
        "commithub.language": {
          "type": "string",
          "default": "auto",
          "enum": ["auto", "tr", "en"],
          "description": "Commit message language"
        },
        "commithub.maxLength": {
          "type": "number",
          "default": 72,
          "description": "Maximum commit message length"
        },
        "commithub.conventionalCommit": {
          "type": "boolean",
          "default": true,
          "description": "Use Conventional Commits format"
        }
      }
    },
    "commands": [
      {
        "command": "commithub.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "commithub.generateCommit",
        "title": "CommitHub: Generate Commit Message",
        "icon": "images/commithub-sparkle.svg"
      },
      {
        "command": "commithub.setApiKey",
        "title": "CommitHub: Set API Key"
      },
      {
        "command": "commithub.setProvider",
        "title": "CommitHub: Set AI Provider"
      },
      {
        "command": "commithub.setModel",
        "title": "CommitHub: Set Model"
      },
      {
        "command": "commithub.setLanguage",
        "title": "CommitHub: Set Language"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "commithub.generateCommit",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "view/title": [
        {
          "command": "commithub.setApiKey",
          "group": "navigation"
        },
        {
          "command": "commithub.setProvider",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "commithub.setApiKey",
          "group": "inline"
        },
        {
          "command": "commithub.setProvider",
          "group": "inline"
        },
        {
          "command": "commithub.setModel",
          "group": "inline"
        },
        {
          "command": "commithub.setLanguage",
          "group": "inline"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "commithub",
          "title": "CommitHub",
          "icon": "images/commithub-sparkle.svg"
        }
      ]
    },
    "views": {
      "commithub": [
        {
          "type": "tree",
          "id": "commithub.settingsView",
          "name": "Settings"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
